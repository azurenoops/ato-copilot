{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "McpChatRequest",
  "description": "Extended MCP chat request with action routing support (FR-014a)",
  "type": "object",
  "required": ["message"],
  "properties": {
    "message": {
      "type": "string",
      "description": "The user's chat message text"
    },
    "conversationId": {
      "type": ["string", "null"],
      "description": "Session identifier for multi-turn conversations"
    },
    "context": {
      "type": ["object", "null"],
      "description": "Freeform context (source, platform, metadata)",
      "additionalProperties": true
    },
    "conversationHistory": {
      "type": ["array", "null"],
      "description": "Previous messages in the conversation",
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": { "type": "string", "enum": ["user", "assistant", "system"] },
          "content": { "type": "string" }
        }
      }
    },
    "action": {
      "type": ["string", "null"],
      "description": "Action type for direct tool routing (bypasses normal chat flow when present)",
      "enum": [
        "remediate",
        "collectEvidence",
        "acknowledgeAlert",
        "dismissAlert",
        "escalateAlert",
        "drillDown",
        "updateFindingStatus",
        "checkPimStatus",
        "activatePim",
        "listEligiblePimRoles",
        null
      ]
    },
    "actionContext": {
      "type": ["object", "null"],
      "description": "Parameters for the action. Required keys depend on the action type.",
      "additionalProperties": { "type": "string" },
      "examples": [
        { "findingId": "abc-123", "controlId": "AC-2", "scope": "/subscriptions/xxx" },
        { "controlId": "AC-2" },
        { "alertId": "alert-456" },
        { "scope": "/subscriptions/xxx", "roleName": "Contributor", "justification": "Remediate AC-2 finding" }
      ]
    }
  },
  "if": {
    "properties": { "action": { "const": "remediate" } }
  },
  "then": {
    "properties": {
      "actionContext": {
        "required": ["findingId"]
      }
    }
  }
}
