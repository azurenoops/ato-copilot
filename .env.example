# ──────────────────────────────────────────────────────────────
# ATO Copilot — Environment Configuration
# Copy to .env and fill in values
# ──────────────────────────────────────────────────────────────

# Run Mode: stdio | http
ATO_RUN_MODE=http

# Azure AD (for Azure Government)
ATO_AZURE_AD__INSTANCE=https://login.microsoftonline.us/
ATO_AZURE_AD__TENANT_ID=your-tenant-id
ATO_AZURE_AD__CLIENT_ID=your-client-id
ATO_AZURE_AD__CLIENT_SECRET=your-client-secret
ATO_AZURE_AD__CLOUD_ENVIRONMENT=AzureUSGovernment

# Azure Gateway
ATO_GATEWAY__AZURE_ENVIRONMENT=AzureUSGovernment
ATO_GATEWAY__DEFAULT_SUBSCRIPTION_ID=your-subscription-id
ATO_GATEWAY__DEFAULT_RESOURCE_GROUP=your-resource-group

# Database
ATO_CONNECTION_STRINGS__DEFAULT_CONNECTION=Data Source=ato-copilot.db

# Server (HTTP mode only)
ATO_SERVER__PORT=3001

# Compliance Agent
ATO_AGENTS__COMPLIANCE__DEFAULT_FRAMEWORK=NIST800-53
ATO_AGENTS__COMPLIANCE__DEFAULT_IMPACT_LEVEL=Moderate
ATO_AGENTS__COMPLIANCE__ENABLE_AUTOMATED_REMEDIATION=false

# Logging
ASPNETCORE_ENVIRONMENT=Development
